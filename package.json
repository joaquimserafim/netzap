{
	"name": "@joaquimserafim/fetchx",
	"version": "1.0.0",
	"description": "Tiny, dependency-free fetch wrapper for Node and browsers: timeouts, signal merging, typed JSON helper, and a client factory.",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.cts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsdown",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"prepublishOnly": "pnpm run build",
		"prepare": "husky",
		"format": "biome check .",
		"format:fix": "biome check --write .",
		"format:ci": "git diff --cached --name-only --diff-filter=ACMR | grep -E '\\.(ts|tsx|js|jsx|json)$' | xargs -r biome check --write || true"
	},
	"keywords": [
		"fetch",
		"http",
		"client",
		"timeout",
		"abort",
		"abortcontroller",
		"signal",
		"json",
		"browser",
		"node",
		"typescript",
		"isomorphic"
	],
	"author": "@joaquimserafim",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/joaquimserafim/fetchx.git"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/node": "^25.8.0",
		"@vitest/coverage-v8": "4.1.6",
		"husky": "^9.1.7",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	}
}
